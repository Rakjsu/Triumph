{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "triumph",
  "version": "2.0.3",
  "identifier": "com.rakjs.triumph",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && cd src-tauri && cargo build --release --bin triumph_worker",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Triumph Nexus",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "target/release/triumph_worker.exe": "triumph_worker.exe",
      "steam_api64.dll": "steam_api64.dll"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMkMzMTBCQTAxOTU1NjAKUldSZ1ZSbWdDekVzMiswRlEwYjl0d0Z0a00wamYvbDJXV2tYUU5TSm1rempqUjhjeFdTdGpZd2oK",
      "endpoints": [
        "https://github.com/Rakjsu/Triumph/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
